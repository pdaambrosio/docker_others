# =============================================================================
# n8n — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here   # required

# ── n8n Encryption ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_32_chars_minimum_random_string

# ── n8n Auth ─────────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_strong_password_here

# ── URLs (update when behind a reverse proxy / domain) ───────────────────────
WEBHOOK_URL=http://localhost:5678
N8N_EDITOR_BASE_URL=http://localhost:5678

# ── Timezone ─────────────────────────────────────────────────────────────────
TZ=UTC
